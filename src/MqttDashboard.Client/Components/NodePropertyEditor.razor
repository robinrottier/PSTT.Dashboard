@using MqttDashboard.Models
@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">

            <!-- Title + Title Position (one row) -->
            <MudGrid Spacing="2">
                <MudItem xs="8">
                    <MudTextField @bind-Value="@Node.Title"
                                  Label="Title"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="4">
                    <MudSelect @bind-Value="@Node.TitlePosition"
                               Label="Position"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true">
                        <MudSelectItem Value="@("Above")">Above</MudSelectItem>
                        <MudSelectItem Value="@("Below")">Below</MudSelectItem>
                        <MudSelectItem Value="@("Left")">Left</MudSelectItem>
                        <MudSelectItem Value="@("Right")">Right</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <!-- Icon and Icon Color -->
            <MudGrid Spacing="2">
                <MudItem xs="6">
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@(Node.Icon ?? Icons.Material.Filled.HideImage)"
                                 Size="MudBlazor.Size.Small" Class="mt-2" />
                        <MudTextField Value="@GetIconName()"
                                      Label="Icon"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      ReadOnly="true"
                                      Style="flex-grow:1;" />
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Size="MudBlazor.Size.Small"
                                       OnClick="OpenIconPicker"
                                       Class="mt-2" />
                        @if (!string.IsNullOrEmpty(Node.Icon))
                        {
                            <MudIconButton Icon="@Icons.Material.Filled.Clear"
                                           Size="MudBlazor.Size.Small"
                                           OnClick="ClearIcon"
                                           Class="mt-2" />
                        }
                    </MudStack>
                </MudItem>
                <MudItem xs="6">
                    <ColorInputRow @bind-Value="Node.IconColor"
                                   Label="Icon Color"
                                   ShowClear="true" />
                </MudItem>
            </MudGrid>

            <!-- Background Color -->
            <ColorInputRow @bind-Value="Node.BackgroundColor"
                           Label="Background Color"
                           Placeholder="None"
                           ShowClear="true" />

            <!-- Background Image (compact: URL + fit on two columns) -->
            <MudGrid Spacing="2">
                <MudItem xs="8">
                    <MudTextField @bind-Value="@Node.BackgroundImageUrl"
                                  Label="Background Image URL"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Placeholder="https://… or data:image/…" />
                </MudItem>
                <MudItem xs="4">
                    <MudSelect @bind-Value="@Node.BackgroundObjectFit"
                               Label="Fit"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Dense="true">
                        <MudSelectItem Value="@("cover")">Cover</MudSelectItem>
                        <MudSelectItem Value="@("contain")">Contain</MudSelectItem>
                        <MudSelectItem Value="@("fill")">Fill</MudSelectItem>
                    </MudSelect>
                </MudItem>
            </MudGrid>

            <!-- Width, Height, Font Size -->
            <MudGrid Spacing="2">
                <MudItem xs="4">
                    <MudNumericField @bind-Value="@Width"
                                     Label="Width (px)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="60" />
                </MudItem>
                <MudItem xs="4">
                    <MudNumericField @bind-Value="@Height"
                                     Label="Height (px)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="45" />
                </MudItem>
                <MudItem xs="4">
                    <MudNumericField @bind-Value="@FontSize"
                                     Label="Font Size (px)"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     Min="0"
                                     Placeholder="default" />
                </MudItem>
            </MudGrid>

            <!-- Link Animation -->
            <MudSelect @bind-Value="@Node.LinkAnimation"
                       Label="Link Animation"
                       Variant="Variant.Outlined"
                       Margin="Margin.Dense"
                       Dense="true"
                       Clearable="true">
                <MudSelectItem Value="@((string?)null)">None</MudSelectItem>
                <MudSelectItem Value="@("Forward")">Forward</MudSelectItem>
                <MudSelectItem Value="@("Reverse")">Reverse</MudSelectItem>
            </MudSelect>

            <!-- MQTT Topics -->
            <MudDivider Class="my-2" />
            <MudText Typo="Typo.subtitle2">MQTT Topics</MudText>
            @for (int i = 0; i < Node.DataTopics.Count; i++)
            {
                var idx = i;
                <div style="display:flex;align-items:center;gap:4px;">
                    <MudTextField Label="@($"Topic {idx + 1}")" Value="@Node.DataTopics[idx]"
                                  ValueChanged="@((string v) => { Node.DataTopics[idx] = v; })"
                                  Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Clear"
                                  OnAdornmentClick="@(() => { Node.DataTopics.RemoveAt(idx); })"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </div>
            }
            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small"
                       OnClick="@(() => Node.DataTopics.Add(string.Empty))">Add Topic</MudButton>

            <!-- Text body -->
            <MudDivider Class="my-2" />
            <MudTextField @bind-Value="@Node.Text"
                          Label="Text"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Lines="4"
                          Placeholder="e.g. Temp: {0:F2}°C&#10;Humidity: {1:F1}%"
                          HelperText="Use {0} for topic 1 value, {1} for topic 2. Supports C# format specs, e.g. {0:F2}." />

            <!-- Node-type-specific settings (driven by [NpXxx] attributes on the model) -->
            @foreach (var category in GetNodeSpecificCategories())
            {
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.caption" Class="mb-1">@category</MudText>
                <NodePropertyRenderer Node="Node" Category="@category" />
            }

            <!-- Custom Metadata -->
            @if (Node.Metadata.Any())
            {
                <MudDivider Class="my-2" />
                <MudText Typo="Typo.caption" Class="mb-1">Custom Metadata</MudText>
                @foreach (var kvp in Node.Metadata.ToList())
                {
                    <MudGrid Spacing="1">
                        <MudItem xs="5">
                            <MudTextField Value="@kvp.Key"
                                          Label="Key"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          ReadOnly="true" />
                        </MudItem>
                        <MudItem xs="6">
                            <MudTextField Value="@kvp.Value"
                                          ValueChanged="@((string val) => UpdateMetadata(kvp.Key, val))"
                                          Label="Value"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="1" Class="d-flex align-center">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           OnClick="@(() => RemoveMetadata(kvp.Key))"
                                           Size="MudBlazor.Size.Small" />
                        </MudItem>
                    </MudGrid>
                }
            }

            <MudButton StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AddMetadata"
                       Color="Color.Primary"
                       Variant="Variant.Text"
                       Size="MudBlazor.Size.Small"
                       Class="mt-1">
                Add Custom Property
            </MudButton>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Size="MudBlazor.Size.Small">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save" Variant="Variant.Filled" Size="MudBlazor.Size.Small">Save</MudButton>
    </DialogActions>
</MudDialog>

