@page "/"
@rendermode InteractiveAuto
@using Blazor.Diagrams
@using Blazor.Diagrams.Components
@using Blazor.Diagrams.Components.Widgets
@using Blazor.Diagrams.Core.Models
@using MqttDashboard.Components

<PageTitle>@(AppState.DisplayName)</PageTitle>

@if (!AppState.IsInteractive || _diagram == null)
{
    <MudProgressCircular Indeterminate="true" />
    <MudText>Loading...</MudText>
}
else
{
    @if (AppState.PageNames.Count > 1 || AppState.IsEditMode)
    {
        <MudPaper Elevation="0" Class="d-flex align-center px-1 py-0"
                  Style="border-bottom:1px solid var(--mud-palette-divider);flex-wrap:nowrap;overflow-x:auto;gap:2px;">
            @for (int i = 0; i < AppState.PageNames.Count; i++)
            {
                var idx = i;
                var isActive = idx == _activePageIndex;
                @if (AppState.IsEditMode)
                {
                    @if (_renamingPageIndex == idx)
                    {
                        <MudTextField @bind-Value="_renameValue"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Style="min-width:80px;max-width:150px;font-size:0.8rem;"
                                      onblur="@(() => CommitRename(idx))"
                                      @onkeydown="@(async e => { if (e.Key == "Enter") await CommitRename(idx); else if (e.Key == "Escape") _renamingPageIndex = -1; })"
                                      AutoFocus="true" />
                    }
                    else
                    {
                        <MudButtonGroup Variant="Variant.Text" Size="Size.Small" Style="flex-shrink:0;">
                            <MudButton OnClick="@(async () => await SwitchToPageAsync(idx))"
                                       Variant="@(isActive ? Variant.Filled : Variant.Text)"
                                       Color="@(isActive ? Color.Primary : Color.Default)"
                                       Size="Size.Small"
                                       Style="min-width:unset;padding:4px 8px;text-transform:none;font-size:0.8rem;"
                                       @ondblclick="@(() => StartRename(idx, AppState.PageNames[idx]))">
                                @AppState.PageNames[idx]
                            </MudButton>
                            @if (AppState.PageNames.Count > 1)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                               Size="Size.Small" Style="padding:2px;"
                                               Color="@(isActive ? Color.Primary : Color.Default)"
                                               OnClick="@(async () => await RemovePageAsync(idx))" />
                            }
                        </MudButtonGroup>
                    }
                }
                else
                {
                    <MudButton OnClick="@(async () => await SwitchToPageAsync(idx))"
                               Variant="@(isActive ? Variant.Filled : Variant.Text)"
                               Color="@(isActive ? Color.Primary : Color.Default)"
                               Size="Size.Small"
                               Style="min-width:unset;padding:4px 12px;text-transform:none;font-size:0.8rem;flex-shrink:0;">
                        @AppState.PageNames[idx]
                    </MudButton>
                }
            }
            @if (AppState.IsEditMode)
            {
                <MudIconButton Icon="@Icons.Material.Filled.Add" Size="Size.Small"
                               Color="Color.Default" Style="opacity:0.7;"
                               OnClick="@(async () => await AddPageAsync())" />
            }
        </MudPaper>
    }
    <MudPaper @key="_diagram" Elevation="2" Style="@($"padding:0;{CanvasStyle}")">
        <div class="mqttdashboard-canvas" tabindex="0" style="width:100%;height:100%;position:relative;" @onkeydown="HandleKeyDown" @ref="_canvasRef">
        @if (AppState.IsEditMode && AppState.IsMultiSelected)
        {
            <MudPaper Elevation="1" Style="position:absolute;z-index:1000;top:4px;left:50%;transform:translateX(-50%);display:flex;gap:2px;padding:2px 4px;border-radius:8px;">
                <MudTooltip Text="Align Left Edges">
                    <MudIconButton Icon="@Icons.Material.Filled.AlignHorizontalLeft" Size="Size.Small" Color="Color.Primary" OnClick='() => AlignNodes("left")' />
                </MudTooltip>
                <MudTooltip Text="Center Horizontally">
                    <MudIconButton Icon="@Icons.Material.Filled.AlignHorizontalCenter" Size="Size.Small" Color="Color.Primary" OnClick='() => AlignNodes("centerH")' />
                </MudTooltip>
                <MudTooltip Text="Align Right Edges">
                    <MudIconButton Icon="@Icons.Material.Filled.AlignHorizontalRight" Size="Size.Small" Color="Color.Primary" OnClick='() => AlignNodes("right")' />
                </MudTooltip>
                <MudDivider Vertical="true" FlexItem="true" />
                <MudTooltip Text="Align Top Edges">
                    <MudIconButton Icon="@Icons.Material.Filled.AlignVerticalTop" Size="Size.Small" Color="Color.Primary" OnClick='() => AlignNodes("top")' />
                </MudTooltip>
                <MudTooltip Text="Center Vertically">
                    <MudIconButton Icon="@Icons.Material.Filled.AlignVerticalCenter" Size="Size.Small" Color="Color.Primary" OnClick='() => AlignNodes("centerV")' />
                </MudTooltip>
                <MudTooltip Text="Align Bottom Edges">
                    <MudIconButton Icon="@Icons.Material.Filled.AlignVerticalBottom" Size="Size.Small" Color="Color.Primary" OnClick='() => AlignNodes("bottom")' />
                </MudTooltip>
                <MudDivider Vertical="true" FlexItem="true" Style="margin:4px 2px;" />
                <MudTooltip Text="Make Same Width">
                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Color="Color.Primary" OnClick="SameWidth" />
                </MudTooltip>
                <MudTooltip Text="Make Same Height">
                    <MudIconButton Icon="@Icons.Material.Filled.SwapVert" Size="Size.Small" Color="Color.Primary" OnClick="SameHeight" />
                </MudTooltip>
            </MudPaper>
        }
        <CascadingValue Value="_diagram" IsFixed="true">
            <DiagramCanvas>
                <Widgets>
                    @if (AppState.IsEditMode)
                    {
                        <GridWidget Size="@(_diagram.Options.GridSize ?? 10)"
                                    Mode="GridMode.Line"
                                    BackgroundColor="white" />
                    }
                </Widgets>
            </DiagramCanvas>
        </CascadingValue>

        @if (AppState.SubscribedTopics.Count == 0)
        {
            <div style="position:absolute;top:0;left:0;right:0;z-index:500;pointer-events:auto;">
                <MudAlert Severity="Severity.Warning" Dense="true" Square="true"
                          Icon="@Icons.Material.Filled.WifiOff"
                          OnClick="@(AppState.IsEditMode ? EventCallback.Factory.Create(this, OpenDashboardProperties) : default)"
                          Style="border-radius:0;">
                    @if (AppState.IsEditMode)
                    {
                        <span>No data topics configured. Add topics in Dashboard Properties.</span>
                    }
                    else
                    {
                        <span>No data topics configured. Switch to edit mode to add MQTT topics.</span>
                    }
                </MudAlert>
            </div>
        }
        </div>
    </MudPaper>
}
