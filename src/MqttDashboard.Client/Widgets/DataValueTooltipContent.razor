@using MqttDashboard.Models

@{
    var hasTopics = Node.DataTopics.Count > 0 && Node.DataTopics.Any(t => !string.IsNullOrEmpty(t));
}
@if (hasTopics)
{
    <div>
        @for (int i = 0; i < Node.DataTopics.Count; i++)
        {
            var topic = Node.DataTopics[i];
            if (string.IsNullOrEmpty(topic)) continue;
            var val     = Node.DataValues.Length > i ? Node.DataValues[i] : null;
            var updated = Node.DataUpdatedTimes.Length > i ? Node.DataUpdatedTimes[i] : null;
            <div>
                @if (Node.DataTopics.Count > 1) { <strong>Topic @(i + 1):</strong> } else { <strong>Topic:</strong> }
                @topic<br/>
                <strong>Value:</strong> @(SanitizeForDisplay(val?.ToString()) ?? "—")
                @if (updated.HasValue)
                {
                    <br/><strong>Updated:</strong> @updated.Value.ToString("HH:mm:ss")
                }
            </div>
        }
    </div>
}
else
{
    <span>No data topic configured</span>
}

@code {
    [Parameter] public TextNodeModel Node { get; set; } = null!;

    private static string? SanitizeForDisplay(string? s)
    {
        if (s == null) return null;
        // Strip characters that are invalid in HTML text nodes (null bytes, lone surrogates, C0/C1 control chars)
        var sb = new System.Text.StringBuilder(s.Length);
        foreach (var ch in s)
        {
            if (ch == '\t' || ch == '\n' || ch == '\r') { sb.Append(ch); continue; }
            if (ch < 0x20) continue;
            if (ch >= 0xD800 && ch <= 0xDFFF) continue;
            if (ch == 0xFFFE || ch == 0xFFFF) continue;
            sb.Append(ch);
        }
        return sb.ToString();
    }
}
