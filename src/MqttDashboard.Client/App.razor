@using Microsoft.AspNetCore.Components.Web
@inject NavigationManager NavigationManager

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@(new Uri(NavigationManager.BaseUri).AbsolutePath)" />

    @* Allow projects to inject head content before shared head *@
    @AdditionalHeadContentBefore

    @* Shared library stylesheets *@
    <!-- MudBlazor CSS - Load first to prevent FOUC -->
    <link rel="preload" href="_content/MudBlazor/MudBlazor.min.css" as="style" />
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
    <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />

    <!-- Blazor.Diagrams -->
    <link href="_content/Z.Blazor.Diagrams/style.min.css" rel="stylesheet" />
    <link href="_content/Z.Blazor.Diagrams/default.styles.min.css" rel="stylesheet" />

    @* Project-specific styles will be injected here *@
    @AdditionalStylesheets

    <link rel="stylesheet" href="_content/MqttDashboard.Client/app.css" />

    <title>Mqtt Dashboard</title>
    <link rel="icon" type="image/svg+xml" href="_content/MqttDashboard.Client/mqttdashboard-icon.svg" />
    <link rel="manifest" href="_content/MqttDashboard.Client/manifest.webmanifest" />
    <meta name="theme-color" content="#594ae2" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="MqttDash" />

    @* Allow projects to inject additional head content *@
    @AdditionalHeadContentAfter

    <HeadOutlet @rendermode="@RenderMode" />
</head>

<body>
    <Routes @rendermode="@RenderMode" />

    @* Shared library scripts *@
    <!-- Blazor.Diagrams must load before blazor.web.js so ZBlazorDiagrams is defined before Blazor makes interop calls -->
    <script src="_content/Z.Blazor.Diagrams/script.min.js"></script>
    <script src="_framework/blazor.web.js"></script>

    <!-- MudBlazor -->
    <script src="_content/MudBlazor/MudBlazor.min.js"></script>

    <!-- Clipboard helpers for copy/paste across browser windows -->
    <script src="_content/MqttDashboard.Client/clipboard.js"></script>
</body>

</html>

@code {
    [Parameter]
    public IComponentRenderMode? RenderMode { get; set; }

    [Parameter]
    public RenderFragment? AdditionalStylesheets { get; set; }

    [Parameter]
    public RenderFragment? AdditionalHeadContentBefore { get; set; }

    [Parameter]
    public RenderFragment? AdditionalHeadContentAfter { get; set; }
}
