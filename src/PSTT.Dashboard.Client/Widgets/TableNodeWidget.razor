@using PSTT.Dashboard.Models
@using PSTT.Dashboard.Services
@using PSTT.Dashboard.Helpers
@using Blazor.Diagrams.Components.Renderers
@using PSTT.Data
@using System.Collections.Concurrent
@using System.Text
@using Microsoft.JSInterop
@inherits BaseNodeWidget<TableNodeModel>
@inject IJSRuntime JS

<div style="@ContainerStyle()"
     class=@("default-node table-node" + (Node.Group != null ? " grouped" : "") + (Node.Selected ? " selected" : ""))
     @ondblclick="OnDoubleClick">

    <div style="display:flex;flex-direction:column;height:100%;width:100%;overflow:hidden;min-width:0;">

        @if (!string.IsNullOrEmpty(Node.Title))
        {
            <div style="font-size:0.75rem;font-weight:500;padding:2px 4px 0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
                @Node.Title
            </div>
        }

        @if (string.IsNullOrEmpty(Node.DataPattern) && Node.DataMode == "PerTable")
        {
            <div style="opacity:0.5;font-size:0.75rem;padding:4px;flex:1;">
                Set a Data Pattern in properties.<br />
                <span style="font-size:0.65rem;">E.g. sensors/{row}/{col}</span>
            </div>
        }
        else if ((_columns == null || _columns.Count == 0) && _data.Count == 0 && Node.DataMode == "PerTable")
        {
            <div style="opacity:0.5;font-size:0.75rem;padding:4px;flex:1;font-style:italic;">
                Waiting for data…
            </div>
        }
        else
        {
            var cols = GetDisplayColumns();
            var rows = GetDisplayRows();

            <div style="flex:1;overflow:auto;min-height:0;min-width:0;">
                <MudSimpleTable Dense="true" Hover="true" Striped="@(_tableStyle?.AltRowBg == null)"
                                Bordered="false"
                                Style="@BuildTableMudStyle()"
                                Class="pa-0">
                    @* colgroup controls column widths; used for both initial sizing and drag-resize *@
                    <colgroup>
                        @if (Node.ShowRowLabels)
                        {
                            <col class="col-label" />
                        }
                        @foreach (var col in cols)
                        {
                            var w = GetColWidthStyle(col.Key, col.Width);
                            <col style="@w" />
                        }
                    </colgroup>

                    @if (Node.ShowHeader && cols.Any())
                    {
                        <thead>
                            <tr style="@BuildHeaderStyle()">
                                @if (Node.ShowRowLabels)
                                {
                                    <th style="@BuildThStyle(null)" class="col-label-th"></th>
                                }
                                @foreach (var col in cols)
                                {
                                    <th data-colkey="@col.Key"
                                        style="@BuildThStyle(col)">
                                        <span class="col-header-text">@(col.Header ?? col.Key)</span>
                                        @if (col.Resizable != false)
                                        {
                                            <div class="col-resize-handle"
                                                 @onmousedown="@(e => OnResizeHandleMouseDown(e, col.Key))"
                                                 @onmousedown:stopPropagation="true"
                                                 @onmousedown:preventDefault="true"></div>
                                        }
                                    </th>
                                }
                            </tr>
                        </thead>
                    }
                    <tbody>
                        @if (!rows.Any())
                        {
                            <tr>
                                <td colspan="@Math.Max(1, cols.Count + (Node.ShowRowLabels ? 1 : 0))"
                                    style="opacity:0.5;font-style:italic;font-size:@FontSizeStyle()">
                                    No data yet…
                                </td>
                            </tr>
                        }
                        @{int rowIdx = 0;}
                        @foreach (var (rowKey, rowLabel) in rows)
                        {
                            var evenRow = rowIdx % 2 == 1;
                            var rowBg = (evenRow && _tableStyle?.AltRowBg is { } ab) ? $"background:{ab};" : string.Empty;
                            <tr style="@rowBg">
                                @if (Node.ShowRowLabels)
                                {
                                    <td style="font-size:@FontSizeStyle();opacity:0.7;font-weight:500;white-space:nowrap;">@rowLabel</td>
                                }
                                @foreach (var col in cols)
                                {
                                    var cellValue = GetCellValue(rowKey, col);
                                    <td style="font-size:@FontSizeStyle();text-align:@(col.Align ?? "left");">@cellValue</td>
                                }
                            </tr>
                            rowIdx++;
                        }
                    </tbody>
                </MudSimpleTable>
            </div>
        }
    </div>

    @foreach (var port in Node.Ports)
    {
        <PortRenderer @key="port" Port="port" Style="@PortStyle(port as NodePortModel)" />
    }
</div>

@code {
    // row → col → raw value string
    private readonly ConcurrentDictionary<string, ConcurrentDictionary<string, string?>> _data = new();
    // ordered column keys discovered from data (PerTable auto-discovery)
    private readonly List<string> _autoColumns = new();
    // ordered row keys discovered from data (PerTable auto-discovery)
    private readonly List<string> _autoRows = new();

    private IDisposable? _subscription;
    private int _lastBridgeGeneration = -1;
    private bool _disposed;

    // Parsed definitions (null = use auto-discovery)
    private List<ColumnDef>? _columns;
    private List<RowDef>?    _rows;
    private List<CellDef>    _cellDefs = new();
    private TableStyleDef?   _tableStyle;

    // Per-cell subscriptions (PerCell mode)
    private readonly List<IDisposable> _cellWatchers = new();

    // Track last parsed JSON to avoid re-parsing on every render
    private string? _lastColumnDefs;
    private string? _lastRowDefs;
    private string? _lastCellDefs;
    private string? _lastDataMode;
    private string? _lastDataPattern;
    private string? _lastTableStyle;

    // ── Column resize ─────────────────────────────────────────────────────────
    // Runtime pixel widths keyed by column key. Populated from ColumnDef.Width on setup
    // and updated when the user drags resize handles. Not persisted automatically.
    private readonly Dictionary<string, double> _columnWidths = new();
    private DotNetObjectReference<TableNodeWidget>? _dotNetRef;

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(140, 80);
        if (Node.Size == null || Node.Size.Width < 140 || Node.Size.Height < 80)
            Node.Size = new(280, 180);
        _dotNetRef = DotNetObjectReference.Create(this);
        base.OnInitialized();
        AppState.BridgeScopeChanged += OnBridgeScopeChanged;
        SetupWatchers();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        SetupWatchers();
    }

    private void SetupWatchers()
    {
        var modeChanged       = Node.DataMode    != _lastDataMode;
        var patternChanged    = Node.DataPattern != _lastDataPattern;
        var columnDefsChanged = Node.ColumnDefs  != _lastColumnDefs;
        var rowDefsChanged    = Node.RowDefs     != _lastRowDefs;
        var cellDefsChanged   = Node.CellDefs    != _lastCellDefs;
        var styleChanged      = Node.TableStyle  != _lastTableStyle;
        var genChanged        = AppState.BridgedDataCache.BridgeGeneration != _lastBridgeGeneration;

        if (!modeChanged && !patternChanged && !columnDefsChanged && !rowDefsChanged
            && !cellDefsChanged && !styleChanged && !genChanged)
            return;

        _lastDataMode    = Node.DataMode;
        _lastDataPattern = Node.DataPattern;
        _lastColumnDefs  = Node.ColumnDefs;
        _lastRowDefs     = Node.RowDefs;
        _lastCellDefs    = Node.CellDefs;
        _lastTableStyle  = Node.TableStyle;
        _lastBridgeGeneration = AppState.BridgedDataCache.BridgeGeneration;

        // Tear down old subscriptions
        _subscription?.Dispose(); _subscription = null;
        foreach (var w in _cellWatchers) w.Dispose();
        _cellWatchers.Clear();
        _data.Clear();
        _autoColumns.Clear();
        _autoRows.Clear();

        // Re-parse definitions
        _columns    = TableDefsParser.ParseColumnDefs(Node.ColumnDefs);
        _rows       = TableDefsParser.ParseRowDefs(Node.RowDefs);
        _cellDefs   = TableDefsParser.ParseCellDefs(Node.CellDefs);
        _tableStyle = TableDefsParser.ParseTableStyle(Node.TableStyle);

        // Reset runtime widths to reflect updated ColumnDefs
        _columnWidths.Clear();
        InitColumnWidths();

        if (Node.DataMode == "PerTable")
            SetupPerTableWatchers();
        else if (Node.DataMode == "PerCell")
            SetupPerCellWatchers();
    }

    // ── PerTable mode ─────────────────────────────────────────────────────────

    private void SetupPerTableWatchers()
    {
        if (string.IsNullOrEmpty(Node.DataPattern)) return;

        var wildcardTopic = PatternToWildcard(Node.DataPattern);
        if (string.IsNullOrEmpty(wildcardTopic)) return;

        // Seed from cache snapshot
        foreach (var kv in AppState.BridgedDataCache.GetSnapshot(wildcardTopic))
            OnTopicValue(kv.Key, kv.Value);

        _subscription = AppState.BridgedDataCache.Subscribe(wildcardTopic, async s =>
        {
            if (s.Status.IsPending || _disposed) return;
            _ = InvokeAsync(() =>
            {
                if (_disposed) return;
                OnTopicValue(s.Key, s.Value);
                StateHasChanged();
            });
            await Task.CompletedTask;
        });
    }

    private void OnTopicValue(string topic, string? value)
    {
        if (!TryExtractSegments(Node.DataPattern, topic, out var row, out var col))
            return;

        var rowDict = _data.GetOrAdd(row!, _ => new ConcurrentDictionary<string, string?>());
        rowDict[col!] = value;

        // Track auto-discovered columns and rows in stable arrival order
        if (!_autoColumns.Contains(col!))
            _autoColumns.Add(col!);
        if (!_autoRows.Contains(row!))
            _autoRows.Add(row!);
    }

    // ── PerCell mode ──────────────────────────────────────────────────────────

    private void SetupPerCellWatchers()
    {
        foreach (var cell in _cellDefs)
        {
            if (string.IsNullOrEmpty(cell.Topic)) continue;

            // Seed from cache
            var initial = AppState.BridgedDataCache.GetValue(cell.Topic);
            if (initial != null)
                StoreCell(cell.Row, cell.Col, initial);

            var capturedCell = cell;
            var watcher = AppState.BridgedDataCache.Subscribe(cell.Topic, async s =>
            {
                if (s.Status.IsPending || _disposed) return;
                _ = InvokeAsync(() =>
                {
                    if (_disposed) return;
                    StoreCell(capturedCell.Row, capturedCell.Col, s.Value);
                    StateHasChanged();
                });
                await Task.CompletedTask;
            });
            _cellWatchers.Add(watcher);
        }
    }

    private void StoreCell(string row, string col, string? value)
    {
        var rowDict = _data.GetOrAdd(row, _ => new ConcurrentDictionary<string, string?>());
        rowDict[col] = value;
    }

    // ── Rendering helpers ─────────────────────────────────────────────────────

    private List<ColumnDef> GetDisplayColumns()
    {
        if (_columns != null && _columns.Count > 0) return _columns;

        if (Node.DataMode == "PerCell")
        {
            var keys = _cellDefs.Select(c => c.Col).Distinct().ToList();
            return keys.Select(k => new ColumnDef(k, k, null, null, null, null)).ToList();
        }

        return _autoColumns.Select(k => new ColumnDef(k, k, null, null, null, null)).ToList();
    }

    private List<(string Key, string Label)> GetDisplayRows()
    {
        if (Node.DataMode == "PerCell")
        {
            return _cellDefs.Select(c => c.Row).Distinct()
                .Select(r => (r, r)).ToList();
        }

        // If RowDefs specified, use them (fixed order, with labels); filter to rows with data
        if (_rows != null && _rows.Count > 0)
        {
            return _rows
                .Where(rd => rd.Key == null || _data.ContainsKey(rd.Key))
                .Select(rd => (rd.Key ?? rd.Label ?? string.Empty, rd.Label ?? rd.Key ?? string.Empty))
                .ToList();
        }

        // Auto-discovered: stable arrival order (not alphabetical)
        return _autoRows.Select(k => (k, k)).ToList();
    }

    private string GetCellValue(string rowKey, ColumnDef col)
    {
        if (Node.DataMode == "PerCell")
        {
            var cellDef = _cellDefs.FirstOrDefault(c => c.Row == rowKey && c.Col == col.Key);
            if (cellDef != null)
            {
                if (_data.TryGetValue(rowKey, out var rowData) && rowData.TryGetValue(col.Key, out var rawVal))
                    return TableDefsParser.ApplyFormat(rawVal, cellDef.Format ?? col.Format);
                return cellDef.Static ?? col.Static ?? string.Empty;
            }
        }

        if (_data.TryGetValue(rowKey, out var rd) && rd.TryGetValue(col.Key, out var raw))
            return TableDefsParser.ApplyFormat(raw, col.Format);
        return col.Static ?? string.Empty;
    }

    // ── Style helpers ─────────────────────────────────────────────────────────

    private string BuildTableMudStyle()
    {
        var sb = new StringBuilder("width:100%;");

        if (_columnWidths.Count > 0)
            sb.Append("table-layout:fixed;");

        if (Node.FontSize.HasValue)
            sb.Append($"font-size:{Node.FontSize}px;");
        else
            sb.Append("font-size:0.75rem;");

        if (!string.IsNullOrEmpty(_tableStyle?.BorderColor))
            sb.Append($"border-color:{_tableStyle.BorderColor};");

        if (!string.IsNullOrEmpty(_tableStyle?.TextColor))
            sb.Append($"color:{_tableStyle.TextColor};");

        return sb.ToString();
    }

    private string BuildHeaderStyle()
    {
        var sb = new StringBuilder();
        if (!string.IsNullOrEmpty(_tableStyle?.HeaderBg))
            sb.Append($"background:{_tableStyle.HeaderBg};");
        if (!string.IsNullOrEmpty(_tableStyle?.HeaderColor))
            sb.Append($"color:{_tableStyle.HeaderColor};");
        return sb.ToString();
    }

    private string BuildThStyle(ColumnDef? col)
    {
        var align = col?.Align ?? "left";
        return $"font-size:{FontSizeStyle()};position:relative;text-align:{align};padding-right:14px;";
    }

    private string FontSizeStyle() =>
        Node.FontSize.HasValue ? $"{Node.FontSize}px" : "0.75rem";

    // ── Column widths ─────────────────────────────────────────────────────────

    private void InitColumnWidths()
    {
        if (_columns == null) return;
        foreach (var col in _columns)
        {
            var px = ParsePx(col.Width);
            if (px > 0)
                _columnWidths[col.Key] = px;
        }
    }

    private string GetColWidthStyle(string key, string? defWidth)
    {
        if (_columnWidths.TryGetValue(key, out var px))
            return $"width:{px:F0}px";
        if (!string.IsNullOrEmpty(defWidth))
            return $"width:{defWidth}";
        return string.Empty;
    }

    private static double ParsePx(string? width)
    {
        if (string.IsNullOrEmpty(width) || !width.EndsWith("px")) return 0;
        return double.TryParse(width[..^2], out var px) ? px : 0;
    }

    // ── Column resize JS interop ──────────────────────────────────────────────

    private async Task OnResizeHandleMouseDown(MouseEventArgs e, string colKey)
    {
        if (_dotNetRef == null) return;
        await JS.InvokeVoidAsync("TableResize.startColumnResize", _dotNetRef, colKey, e.ClientX);
    }

    [JSInvokable]
    public void OnColResizeBegin(string colKey, double renderedWidth)
    {
        // JS measured the actual <th> offsetWidth; store it so subsequent deltas are applied correctly.
        _columnWidths[colKey] = Math.Max(30, renderedWidth);
    }

    [JSInvokable]
    public void OnColResizeDelta(string colKey, double deltaX)
    {
        _columnWidths.TryGetValue(colKey, out var current);
        _columnWidths[colKey] = Math.Max(30, current + deltaX);
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public void OnColResizeEnd(string colKey)
    {
        // Width is already stored in _columnWidths. No auto-persist to ColumnDefs JSON here —
        // user can use the property editor to set permanent widths.
        InvokeAsync(StateHasChanged);
    }

    // ── Pattern parsing ───────────────────────────────────────────────────────

    private static string PatternToWildcard(string? pattern)
        => TableTopicParser.PatternToWildcard(pattern);

    private static bool TryExtractSegments(string? pattern, string topic, out string? row, out string? col)
        => TableTopicParser.TryExtractSegments(pattern, topic, out row, out col);

    // ── Lifecycle ─────────────────────────────────────────────────────────────

    private void OnBridgeScopeChanged()
    {
        _ = InvokeAsync(() =>
        {
            _subscription?.Dispose(); _subscription = null;
            _lastBridgeGeneration = -1; // force re-subscribe
            SetupWatchers();
            StateHasChanged();
        });
    }

    public override void Dispose()
    {
        _disposed = true;
        AppState.BridgeScopeChanged -= OnBridgeScopeChanged;
        _subscription?.Dispose(); _subscription = null;
        foreach (var w in _cellWatchers) w.Dispose();
        _cellWatchers.Clear();
        _dotNetRef?.Dispose();
        base.Dispose();
    }
}
