@using PSTT.Dashboard.Models
@using PSTT.Dashboard.Services
@using PSTT.Dashboard.Components
@using Blazor.Diagrams.Components.Renderers
@using PSTT.Data
@using System.Collections.Concurrent
@inherits BaseNodeWidget<TreeViewNodeModel>

<div style="@ContainerStyle()"
     class=@("default-node treeview-node" + (Node.Group != null ? " grouped" : "") + (Node.Selected ? " selected" : ""))
     @ondblclick="OnDoubleClick">
    <div style="display:flex;flex-direction:column;height:100%;overflow:hidden;min-width:0;">
        @if (!string.IsNullOrEmpty(Node.Title))
        {
            <div style="font-size:0.75rem;font-weight:500;padding:2px 4px 0;">@Node.Title</div>
        }
        @if (string.IsNullOrEmpty(RootTopicValue))
        {
            <div style="opacity:0.5;font-size:0.75rem;padding:4px;">Set Root Topic in properties.</div>
        }
        else
        {
            <div style="flex:1;overflow-y:auto;font-size:0.75rem;min-height:0;padding:2px 0;">
                @foreach (var node in _topicTree)
                {
                    <TopicTreeNode @key="@node.FullTopic"
                                   Node="node"
                                   ShowActions="false"
                                   HighlightedTopics="@_highlightedTopics"
                                   ExpandedPaths="_expandedPaths"
                                   OnToggleExpand="EventCallback.Factory.Create<string>(this, ToggleExpand)" />
                }
            </div>
        }
    </div>
    @foreach (var port in Node.Ports)
    {
        <PortRenderer @key="port" Port="port" Style="@PortStyle(port as NodePortModel)" />
    }
</div>

@code {
    private string RootTopicValue => Node.DataTopics.Count > 0 ? Node.DataTopics[0] : string.Empty;

    private List<TopicNode> _topicTree = [];
    private readonly HashSet<string> _expandedPaths = new();
    private readonly HashSet<string> _highlightedTopics = new();
    private readonly ConcurrentDictionary<string, DateTime> _changedAt = new();
    private readonly ConcurrentDictionary<string, string?> _values = new();
    private bool _disposed;
    private IDisposable? _watchSubscription;
    private IDisposable? _rootWatchSubscription;
    private System.Threading.Timer? _debounceTimer;
    private System.Threading.Timer? _highlightClearTimer;

    private static bool IsGlobalWildcard(string topic) => topic is "#";

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(120, 80);
        if (Node.Size == null || Node.Size.Width < 120 || Node.Size.Height < 80)
            Node.Size = new(200, 200);
        base.OnInitialized();
        _debounceTimer = new System.Threading.Timer(OnDebounceElapsed, null,
            System.Threading.Timeout.Infinite, System.Threading.Timeout.Infinite);
        _highlightClearTimer = new System.Threading.Timer(OnHighlightClearElapsed, null,
            System.Threading.Timeout.Infinite, System.Threading.Timeout.Infinite);
        SetupWatchers();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        SetupWatchers();
    }

    private void SetupWatchers()
    {
        _watchSubscription?.Dispose(); _watchSubscription = null;
        _rootWatchSubscription?.Dispose(); _rootWatchSubscription = null;
        _values.Clear();
        _changedAt.Clear();
        _expandedPaths.Clear();

        if (string.IsNullOrEmpty(RootTopicValue)) { _topicTree = []; return; }

        var isGlobal = IsGlobalWildcard(RootTopicValue);
        var prefix = isGlobal ? null : RootTopicValue.TrimEnd('/') + "/";

        // For the global '#' root topic, use the source DataCache directly so all
        // available MQTT data is visible regardless of the dashboard's bridge scope.
        // For all other topics, use BridgedDataCache (dashboard-scoped view).
        var cache = isGlobal ? AppState.DataCache : (ICache<string, string>)AppState.BridgedDataCache;

        foreach (var kv in cache.GetSnapshot())
        {
            if (isGlobal || kv.Key == RootTopicValue || (prefix != null && kv.Key.StartsWith(prefix)))
                _values[kv.Key] = kv.Value;
        }

        RebuildTree();
        AutoExpandRoots();

        var wildcardTopic = isGlobal ? RootTopicValue : (RootTopicValue.TrimEnd('/') + "/#");
        _watchSubscription = cache.Subscribe(wildcardTopic, async sub =>
        {
            if (sub.Status.IsPending) return;
            await OnTopicChangedAsync(sub.Key, sub.Value);
        });

        if (!isGlobal)
        {
            _rootWatchSubscription = AppState.BridgedDataCache.Subscribe(RootTopicValue, async sub =>
            {
                if (sub.Status.IsPending) return;
                await OnTopicChangedAsync(sub.Key, sub.Value);
            });
        }
    }

    private Task OnTopicChangedAsync(string topic, string? value)
    {
        if (_disposed) return Task.CompletedTask;
        _values[topic] = value;
        _changedAt[topic] = DateTime.Now;
        _debounceTimer?.Change(80, System.Threading.Timeout.Infinite);
        return Task.CompletedTask;
    }

    private void OnDebounceElapsed(object? _)
    {
        if (_disposed) return;
        RebuildTree();
        UpdateHighlights();
        try { InvokeAsync(StateHasChanged); } catch { }
        _highlightClearTimer?.Change(2200, System.Threading.Timeout.Infinite);
    }

    private void OnHighlightClearElapsed(object? _)
    {
        if (_disposed) return;
        UpdateHighlights();
        try { InvokeAsync(StateHasChanged); } catch { }
    }

    private void UpdateHighlights()
    {
        _highlightedTopics.Clear();
        foreach (var (topic, changedTime) in _changedAt)
        {
            if ((DateTime.Now - changedTime).TotalSeconds < 2)
                _highlightedTopics.Add(topic);
        }
    }

    private void RebuildTree()
    {
        if (string.IsNullOrEmpty(RootTopicValue)) { _topicTree = []; return; }

        var root = new Dictionary<string, TopicNode>();
        foreach (var (topic, value) in _values.OrderBy(kv => kv.Key))
        {
            var parts = topic.Split('/');
            var current = root;
            TopicNode? node = null;
            for (int i = 0; i < parts.Length; i++)
            {
                var part = parts[i];
                if (!current.TryGetValue(part, out node))
                {
                    node = new TopicNode
                    {
                        Label = part,
                        FullTopic = string.Join("/", parts[..(i + 1)])
                    };
                    current[part] = node;
                }
                if (i == parts.Length - 1)
                    node.Value = value ?? string.Empty;
                current = node.ChildMap;
            }
        }

        FlattenTree(root);
        _topicTree = root.Values.OrderBy(n => n.Label).ToList();
    }

    private static void FlattenTree(Dictionary<string, TopicNode> map)
    {
        foreach (var node in map.Values)
        {
            node.Children = node.ChildMap.Values.OrderBy(n => n.Label).ToList();
            FlattenTree(node.ChildMap);
        }
    }

    private void AutoExpandRoots()
    {
        foreach (var node in _topicTree)
        {
            if (!node.IsLeaf)
                _expandedPaths.Add(node.FullTopic);
        }
    }

    private void ToggleExpand(string fullTopic)
    {
        if (!_expandedPaths.Remove(fullTopic))
            _expandedPaths.Add(fullTopic);
        StateHasChanged();
    }

    public override void Dispose()
    {
        _disposed = true;
        _debounceTimer?.Dispose();
        _highlightClearTimer?.Dispose();
        _watchSubscription?.Dispose();
        _rootWatchSubscription?.Dispose();
        base.Dispose();
    }
}
