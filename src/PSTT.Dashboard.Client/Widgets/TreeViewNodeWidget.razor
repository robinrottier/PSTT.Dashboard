@using PSTT.Dashboard.Models
@using PSTT.Dashboard.Services
@using Blazor.Diagrams.Components.Renderers
@inherits BaseNodeWidget<TreeViewNodeModel>

<div style="@ContainerStyle()"
     class=@("default-node treeview-node" + (Node.Group != null ? " grouped" : "") + (Node.Selected ? " selected" : ""))
     @ondblclick="OnDoubleClick">
    <div style="display:flex;flex-direction:column;height:100%;overflow:hidden;min-width:0;">
        @if (!string.IsNullOrEmpty(Node.Title))
        {
            <div style="font-size:0.75rem;font-weight:500;padding:2px 4px 0;">@Node.Title</div>
        }
        @if (string.IsNullOrEmpty(RootTopicValue))
        {
            <div style="opacity:0.5;font-size:0.75rem;padding:4px;">Set Root Topic in properties.</div>
        }
        else
        {
            <div style="flex:1;overflow-y:auto;font-size:0.75rem;min-height:0;padding:2px 0;">
                <MudTreeView T="TreeNode" Dense="true" Hover="true"
                             Style="font-size:0.75rem;font-family:monospace;overflow:auto;width:100%;height:100%;">
                    @RenderMudTreeItem(_tree)
                </MudTreeView>
            </div>
        }
    </div>
    @foreach (var port in Node.Ports)
    {
        <PortRenderer @key="port" Port="port" Style="@PortStyle(port as NodePortModel)" />
    }
</div>

@code {
    // The root MQTT topic is DataTopics[0] (inherited from TextNodeModel).
    private string RootTopicValue => Node.DataTopics.Count > 0 ? Node.DataTopics[0] : string.Empty;

    private TreeNode _tree = new("", "");
    private bool _disposed;
    private IDisposable? _watchSubscription;
    private IDisposable? _rootWatchSubscription;
    private readonly Dictionary<string, bool> _expandedState = new();
    private readonly Dictionary<string, DateTime> _changedAt = new();
    private readonly Dictionary<string, string?> _values = new();
    private bool _pendingRebuild;
    private System.Threading.Timer? _debounceTimer;
    private System.Threading.Timer? _highlightClearTimer;

    private sealed class TreeNode(string fullTopic, string label)
    {
        public string FullTopic { get; } = fullTopic;
        public string Label { get; } = label;
        public string? Value { get; set; }
        public List<TreeNode> Children { get; set; } = [];
        public bool Expanded { get; set; } = true;
    }

    protected override void OnInitialized()
    {
        Node.MinimumDimensions = new(120, 80);
        if (Node.Size == null || Node.Size.Width < 120 || Node.Size.Height < 80)
            Node.Size = new(200, 200);
        base.OnInitialized();
        _debounceTimer = new System.Threading.Timer(OnDebounceElapsed, null,
            System.Threading.Timeout.Infinite, System.Threading.Timeout.Infinite);
        _highlightClearTimer = new System.Threading.Timer(OnHighlightClearElapsed, null,
            System.Threading.Timeout.Infinite, System.Threading.Timeout.Infinite);
        SetupWatchers();
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        SetupWatchers();
    }

    // Returns true when the root topic is a bare wildcard that matches all topics,
    // e.g. "#" — in that case we must not append "/#" and have no separate root sub.
    private static bool IsGlobalWildcard(string topic) => topic is "#";

    private void SetupWatchers()
    {
        _watchSubscription?.Dispose(); _watchSubscription = null;
        _rootWatchSubscription?.Dispose(); _rootWatchSubscription = null;
        _values.Clear();

        if (string.IsNullOrEmpty(RootTopicValue)) { _tree = new("", ""); return; }

        var isGlobal = IsGlobalWildcard(RootTopicValue);

        // Seed _values from the current cache snapshot so the tree is populated immediately
        // on first render (before any subscription callbacks fire).
        var prefix = isGlobal ? null : RootTopicValue.TrimEnd('/') + "/";
        foreach (var kv in AppState.BridgedDataCache.GetSnapshot())
        {
            if (isGlobal || kv.Key == RootTopicValue || (prefix != null && kv.Key.StartsWith(prefix)))
                _values[kv.Key] = kv.Value;
        }

        RebuildTree();

        // When the root topic already contains "#", subscribe as-is; otherwise append "/#"
        // to capture all sub-topics below the root.
        var wildcardTopic = isGlobal ? RootTopicValue : (RootTopicValue.TrimEnd('/') + "/#");
        _watchSubscription = AppState.BridgedDataCache.Subscribe(wildcardTopic, async sub =>
        {
            if (sub.Status.IsPending) return;
            await OnTopicChangedAsync(sub.Key, sub.Value);
        });

        // Subscribe to the exact root topic separately (only when not already a global wildcard).
        if (!isGlobal)
        {
            _rootWatchSubscription = AppState.BridgedDataCache.Subscribe(RootTopicValue, async sub =>
            {
                if (sub.Status.IsPending) return;
                await OnTopicChangedAsync(sub.Key, sub.Value);
            });
        }
    }

    private Task OnTopicChangedAsync(string topic, string? value)
    {
        if (_disposed) return Task.CompletedTask;
        _values[topic] = value;
        _changedAt[topic] = DateTime.Now;
        var node = FindNode(_tree, topic);
        if (node != null)
            node.Value = value;
        else
            _pendingRebuild = true;

        // Debounce: coalesce rapid MQTT bursts into one render
        _debounceTimer?.Change(80, System.Threading.Timeout.Infinite);
        return Task.CompletedTask;
    }

    private void OnDebounceElapsed(object? _)
    {
        if (_disposed) return;
        if (_pendingRebuild)
        {
            _pendingRebuild = false;
            SaveExpansionState(_tree);
            RebuildTree();
            RestoreExpansionState(_tree);
        }
        try { InvokeAsync(StateHasChanged); } catch { }
        // Schedule a re-render to clear the 2s highlight window once it expires
        _highlightClearTimer?.Change(2200, System.Threading.Timeout.Infinite);
    }

    private void OnHighlightClearElapsed(object? _)
    {
        if (_disposed) return;
        try { InvokeAsync(StateHasChanged); } catch { }
    }

    private void RebuildTree()
    {
        if (string.IsNullOrEmpty(RootTopicValue)) { _tree = new("", ""); return; }

        var isGlobal = IsGlobalWildcard(RootTopicValue);
        var root = new TreeNode(RootTopicValue, isGlobal ? "(all topics)" : RootTopicValue.Split('/').Last());
        root.Value = isGlobal ? null : (_values.TryGetValue(RootTopicValue, out var rv) ? rv : AppState.BridgedDataCache.GetValue(RootTopicValue));
        root.Expanded = true;

        // For global "#", include ALL values with no prefix filter.
        // For a specific root, include only sub-topics below it.
        var prefix = isGlobal ? null : RootTopicValue.TrimEnd('/') + "/";
        var matches = prefix == null
            ? _values
            : (IEnumerable<KeyValuePair<string, string?>>)_values.Where(kvp => kvp.Key.StartsWith(prefix));

        foreach (var kvp in matches.OrderBy(x => x.Key))
        {
            // Compute relative path from the root (or from the topic root for global wildcard).
            var relativePath = prefix == null
                ? kvp.Key
                : kvp.Key.Substring(RootTopicValue.Length).TrimStart('/');

            var relativeParts = relativePath.Split('/');
            var node = root;
            var currentPath = prefix == null ? "" : RootTopicValue;
            var depth = 0;
            foreach (var part in relativeParts)
            {
                if (string.IsNullOrEmpty(part)) continue;
                currentPath = string.IsNullOrEmpty(currentPath) ? part : currentPath + "/" + part;
                depth++;
                var child = node.Children.FirstOrDefault(c => c.Label == part);
                if (child == null)
                {
                    child = new TreeNode(currentPath, part) { Expanded = depth <= 1 };
                    node.Children.Add(child);
                }
                node = child;
            }
            node.Value = kvp.Value;
        }
        _tree = root;
    }

    private void SaveExpansionState(TreeNode node)
    {
        _expandedState[node.FullTopic] = node.Expanded;
        foreach (var child in node.Children)
            SaveExpansionState(child);
    }

    private void RestoreExpansionState(TreeNode node)
    {
        if (_expandedState.TryGetValue(node.FullTopic, out var expanded))
            node.Expanded = expanded;
        foreach (var child in node.Children)
            RestoreExpansionState(child);
    }

    private TreeNode? FindNode(TreeNode node, string fullTopic)
    {
        if (node.FullTopic == fullTopic) return node;
        foreach (var child in node.Children)
        {
            var found = FindNode(child, fullTopic);
            if (found != null) return found;
        }
        return null;
    }

    private RenderFragment RenderMudTreeItem(TreeNode node) => builder =>
    {
        var isHighlighted = _changedAt.TryGetValue(node.FullTopic, out var changedTime) &&
                            (DateTime.Now - changedTime).TotalSeconds < 2;

        builder.OpenComponent<MudTreeViewItem<TreeNode>>(0);
        builder.AddAttribute(1, "Value", node);
        builder.AddAttribute(2, "Expanded", node.Expanded);
        builder.AddAttribute(3, "ExpandedChanged", EventCallback.Factory.Create<bool>(this, v => node.Expanded = v));

        var displayText = node.Children.Count > 0
            ? node.Label
            : (Node.ShowValues && node.Value != null ? $"{node.Label}: {node.Value}" : node.Label);
        builder.AddAttribute(4, "Text", displayText);

        if (isHighlighted)
            builder.AddAttribute(5, "Style", "background:var(--mud-palette-warning-hover);");

        if (node.Children.Count > 0)
        {
            builder.AddAttribute(6, "ChildContent", (RenderFragment)(childBuilder =>
            {
                foreach (var child in node.Children)
                    childBuilder.AddContent(0, RenderMudTreeItem(child));
            }));
        }

        builder.CloseComponent();
    };

    public override void Dispose()
    {
        _disposed = true;
        _debounceTimer?.Dispose();
        _highlightClearTimer?.Dispose();
        _watchSubscription?.Dispose();
        _rootWatchSubscription?.Dispose();
        base.Dispose();
    }
}
