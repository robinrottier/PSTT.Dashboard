@using MudBlazor
@using PSTT.Dashboard.Services
@using PSTT.Dashboard.Models
@using Microsoft.Extensions.Logging
@inject PSTT.Dashboard.Services.IDashboardService DashboardService
@inject MudBlazor.IDialogService DialogService
@inject HttpClient Http
@inject ILogger<DashboardPickerDialog> Logger
@inject ILoggerFactory LoggerFactory
@inject IRemoteRepoService RemoteRepoService

<MudDialog Style="min-width:420px;">
    <TitleContent>
        <MudText Typo="Typo.h6">Open Dashboard</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="1">
            @if (_remoteRepos.Count > 0)
            {
                <MudSelect T="string" Value="_selectedSource" Label="Source" Variant="Variant.Outlined"
                           Dense="true" Margin="Margin.Dense" Disabled="_isLoading"
                           ValueChanged="OnSourceChanged">
                    <MudSelectItem T="string" Value=@("local")>Local</MudSelectItem>
                    @foreach (var repo in _remoteRepos)
                    {
                        <MudSelectItem T="string" Value="@repo.Name">@repo.Name</MudSelectItem>
                    }
                </MudSelect>
            }

            <DashboardFileListPanel Names="_names" IsLoading="_isLoading" SelectedName="_selected"
                                    AllowDelete="@(_selectedSource == "local")"
                                    OnNameSelected="n => _selected = n"
                                    OnDeleteClicked="DeleteAsync" />

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Size="Size.Small">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" OnClick="Submit"
                   Disabled="@(string.IsNullOrEmpty(_selected) || _isLoading)">Open</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private string? _selected;
    private string _selectedSource = "local";
    private List<string> _names = [];
    private List<RemoteRepoInfo> _remoteRepos = [];
    private bool _isLoading = false;
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _remoteRepos = await RemoteRepoService.GetRemoteReposAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load remote repositories");
            _errorMessage = $"Failed to load remote repositories: {ex.Message}";
            _remoteRepos = [];
        }
        await RefreshList();
    }

    private async Task OnSourceChanged(string source)
    {
        _selectedSource = source;
        _selected = null;
        await RefreshList();
    }

    private async Task RefreshList()
    {
        _names = [];
        _errorMessage = string.Empty;
        _isLoading = true;
        StateHasChanged(); // Show spinner before await

        try
        {
            if (_selectedSource == "local")
            {
                _names = await DashboardService.ListDashboardsAsync();
            }
            else
            {
                var repo = _remoteRepos.FirstOrDefault(r => r.Name == _selectedSource);
                if (repo != null)
                {
                    Logger.LogInformation("Loading dashboards from remote '{RepoName}'", repo.Name);
                    var svc = new RemoteProxyDashboardService(Http, repo.Name,
                        LoggerFactory.CreateLogger<RemoteProxyDashboardService>());
                    _names = await svc.ListDashboardsAsync();
                    Logger.LogInformation("Loaded {Count} dashboards from remote '{RepoName}'", _names.Count, repo.Name);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard list from {Source}", _selectedSource);
            _errorMessage = $"Failed to load from {_selectedSource}: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }

        StateHasChanged();
    }

    private async Task DeleteAsync(string name)
    {
        if (_selectedSource != "local") return;

        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Dashboard",
            $"Delete '{name}'? This cannot be undone.",
            yesText: "Delete", cancelText: "Cancel");
        if (confirmed != true) return;

        var ok = await DashboardService.DeleteDashboardByNameAsync(name);
        if (ok)
        {
            _names = _names.Where(n => n != name).ToList();
            if (_selected == name) _selected = null;
        }
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok((_selectedSource, _selected ?? string.Empty)));
    private void Cancel() => MudDialog.Cancel();
}