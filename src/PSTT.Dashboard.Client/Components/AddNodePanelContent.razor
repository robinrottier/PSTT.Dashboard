@using MudBlazor

<MudGrid Spacing="1" Style="width:290px;">
    @foreach (var (nodeType, icon, label, caption) in _nodeTypes)
    {
        var nt = nodeType;
        <MudItem xs="4">
            <MudPaper Class="pa-2 d-flex flex-column align-center"
                      Style="cursor:pointer;"
                      Outlined="true"
                      @onclick="() => Select(nt)">
                <MudIcon Icon="@icon" Size="Size.Medium" Color="Color.Primary" />
                <MudText Typo="Typo.caption" Class="mt-1">@label</MudText>
            </MudPaper>
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter] public EventCallback<string> OnNodeTypeSelected { get; set; }

    private static readonly (string NodeType, string Icon, string Label, string Caption)[] _nodeTypes =
    [
        ("Text",     Icons.Material.Filled.TextFields,  "Text",      "Display MQTT values"),
        ("Gauge",    Icons.Material.Filled.Speed,        "Gauge",     "Gauge with min/max"),
        ("Switch",   Icons.Material.Filled.ToggleOn,     "Switch",    "Toggle + publish"),
        ("Battery",  Icons.Material.Filled.Battery5Bar,  "Battery",   "Battery level"),
        ("Log",      Icons.Material.Filled.ListAlt,      "Log",       "MQTT message log"),
        ("TreeView", Icons.Material.Filled.AccountTree,  "Tree View", "Hierarchical topics"),
    ];

    private async Task Select(string nodeType) => await OnNodeTypeSelected.InvokeAsync(nodeType);
}
