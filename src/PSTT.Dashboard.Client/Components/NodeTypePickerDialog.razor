@using MudBlazor

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-3">Choose the type of node to add:</MudText>
        <MudGrid Spacing="2">
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;border:2px solid transparent;" 
                          Outlined="true" @onclick='() => Select("Text")'>
                    <MudIcon Icon="@Icons.Material.Filled.TextFields" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mt-1">Text</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Display MQTT values</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;" 
                          Outlined="true" @onclick='() => Select("Gauge")'>
                    <MudIcon Icon="@Icons.Material.Filled.Speed" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mt-1">Gauge</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Gauge with min/max</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;" 
                          Outlined="true" @onclick='() => Select("Switch")'>
                    <MudIcon Icon="@Icons.Material.Filled.ToggleOn" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mt-1">Switch</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Toggle + publish to MQTT</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;"
                          Outlined="true" @onclick='() => Select("Battery")'>
                    <MudIcon Icon="@Icons.Material.Filled.Battery5Bar" Size="Size.Large" Color="Color.Success" />
                    <MudText Typo="Typo.body2" Class="mt-1">Battery</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Battery level indicator</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;"
                          Outlined="true" @onclick='() => Select("Log")'>
                    <MudIcon Icon="@Icons.Material.Filled.ListAlt" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mt-1">Log</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">MQTT message log</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;"
                          Outlined="true" @onclick='() => Select("TreeView")'>
                    <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mt-1">Tree View</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Hierarchical topic view</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;"
                          Outlined="true" @onclick='() => Select("Slider")'>
                    <MudIcon Icon="@Icons.Material.Filled.LinearScale" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mt-1">Slider</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Adjust and publish value</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;"
                          Outlined="true" @onclick='() => Select("Button")'>
                    <MudIcon Icon="@Icons.Material.Filled.SmartButton" Size="Size.Large" Color="Color.Primary" />
                    <MudText Typo="Typo.body2" Class="mt-1">Button</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Click to publish value</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;"
                          Outlined="true" @onclick='() => Select("Html")'>
                    <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.body2" Class="mt-1">HTML</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Static HTML content</MudText>
                </MudPaper>
            </MudItem>
            <MudItem xs="4">
                <MudPaper Class="pa-3 d-flex flex-column align-center" Style="cursor:pointer;"
                          Outlined="true" @onclick='() => Select("IFrame")'>
                    <MudIcon Icon="@Icons.Material.Filled.OpenInBrowser" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Typo="Typo.body2" Class="mt-1">IFrame</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Embedded web page</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    private void Select(string nodeType) => MudDialog.Close(DialogResult.Ok(nodeType));
    private void Cancel() => MudDialog.Cancel();
}
