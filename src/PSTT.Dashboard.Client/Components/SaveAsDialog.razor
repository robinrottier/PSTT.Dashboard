@using MudBlazor
@using PSTT.Dashboard.Models
@using PSTT.Dashboard.Services
@using Microsoft.Extensions.Logging
@inject PSTT.Dashboard.Services.IDashboardService DashboardService
@inject MudBlazor.IDialogService DialogService
@inject HttpClient Http
@inject ILogger<SaveAsDialog> Logger

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Save Dashboard As</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="2">
            <!-- Destination source -->
            @if (_remoteRepos.Count > 0)
            {
                <MudSelect T="string" Value="_destination" Label="Destination" Variant="Variant.Outlined" Dense="true"
                           ValueChanged="OnDestinationChanged" Margin="Margin.Dense">
                    <MudSelectItem T="string" Value="@("local")">Local</MudSelectItem>
                    @foreach (var repo in _remoteRepos)
                    {
                        <MudSelectItem T="string" Value="@repo.Name">@repo.Name</MudSelectItem>
                    }
                </MudSelect>
            }

            <!-- Name input -->
            <MudTextField T="string" @bind-Value="_name" Label="Save As Dashboard Name" Variant="Variant.Outlined" Dense="true"
                          FullWidth="true" AutoFocus="true" Margin="Margin.Dense" />

            <!-- Existing names in destination as listbox -->
            @if (_existingNames.Count > 0)
            {
                <div style="display: flex; flex-direction: column; min-height: 0;">
                    <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="margin-bottom: 4px;">Existing dashboards:</MudText>
                    <div style="flex: 1; overflow-y: auto; border: 1px solid var(--mud-palette-lines-default); border-radius: 4px; background: var(--mud-palette-background);">
                        <div style="min-height: calc(1.5em * 5 + 8px);">
                            @foreach (var name in _existingNames)
                            {
                                <div style="padding: 6px 8px; cursor: pointer; border-bottom: 1px solid var(--mud-palette-lines-default); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 0.875rem;"
                                     @onclick="@(() => _name = name)">
                                    @name
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }

            <!-- Error message if loading failed -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error">@_errorMessage</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_name))">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string InitialName { get; set; } = string.Empty;
    [Parameter] public List<RemoteRepoInfo> RemoteRepos { get; set; } = [];

    private string _name = string.Empty;
    private string _destination = "local";
    private List<RemoteRepoInfo> _remoteRepos = [];
    private List<string> _existingNames = [];
    private string _errorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _remoteRepos = RemoteRepos;
        _name = InitialName;
        await RefreshExistingNames();
    }

    private async Task OnDestinationChanged(string dest)
    {
        _destination = dest;
        _errorMessage = string.Empty;
        await RefreshExistingNames();
    }

    private async Task RefreshExistingNames()
    {
        _existingNames = [];
        try
        {
            if (_destination == "local")
            {
                _existingNames = await DashboardService.ListDashboardsAsync();
            }
            else
            {
                var repo = _remoteRepos.FirstOrDefault(r => r.Name == _destination);
                if (repo != null)
                {
                    var service = new RemoteProxyDashboardService(Http, repo.Name);
                    _existingNames = await service.ListDashboardsAsync();
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard list for destination {Destination}", _destination);
            _errorMessage = $"Failed to load dashboards: {ex.Message}";
        }
        StateHasChanged();
    }

    private void Submit() => 
        MudDialog.Close(DialogResult.Ok((_destination, _name.Trim())));

    private void Cancel() => MudDialog.Cancel();
}
