@using MudBlazor
@using PSTT.Dashboard.Models
@using PSTT.Dashboard.Services
@using Microsoft.Extensions.Logging
@inject PSTT.Dashboard.Services.IDashboardService DashboardService
@inject MudBlazor.IDialogService DialogService
@inject HttpClient Http
@inject ILogger<SaveAsDialog> Logger
@inject ILoggerFactory LoggerFactory
@inject IRemoteRepoService RemoteRepoService

<MudDialog Style="min-width:420px;">
    <TitleContent>
        <MudText Typo="Typo.h6">Save Dashboard As</MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="1">
            <!-- Destination source -->
            @if (_remoteRepos.Count > 0)
            {
                <MudSelect T="string" Value="_destination" Label="Destination" Variant="Variant.Outlined" Dense="true"
                           ValueChanged="OnDestinationChanged" Margin="Margin.Dense" Disabled="_isLoading">
                    <MudSelectItem T="string" Value="@("local")">Local</MudSelectItem>
                    @foreach (var repo in _remoteRepos)
                    {
                        <MudSelectItem T="string" Value="@repo.Name">@repo.Name</MudSelectItem>
                    }
                </MudSelect>
            }

            <!-- Name input -->
            <MudTextField T="string" @bind-Value="_name" Label="Save As Dashboard Name" Variant="Variant.Outlined"
                          FullWidth="true" AutoFocus="true" Margin="Margin.Dense" />

            <!-- Existing names — click to populate name field -->
            <MudText Typo="Typo.caption" Class="mud-text-secondary" Style="margin-bottom:2px;">Existing dashboards (click to overwrite):</MudText>
            <DashboardFileListPanel Names="_existingNames" IsLoading="_isLoading" SelectedName="_name"
                                    OnNameSelected="n => _name = n" />

            <!-- Error message if loading failed -->
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Dense="true">@_errorMessage</MudAlert>
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Size="Size.Small">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" OnClick="Submit"
                   Disabled="@(string.IsNullOrWhiteSpace(_name) || _isLoading)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public string InitialName { get; set; } = string.Empty;

    private string _name = string.Empty;
    private string _destination = "local";
    private List<RemoteRepoInfo> _remoteRepos = [];
    private List<string> _existingNames = [];
    private string _errorMessage = string.Empty;
    private bool _isLoading = false;

    protected override async Task OnInitializedAsync()
    {
        _name = InitialName;
        try { _remoteRepos = await RemoteRepoService.GetRemoteReposAsync(); }
        catch { _remoteRepos = []; }
        await RefreshExistingNames();
    }

    private async Task OnDestinationChanged(string dest)
    {
        _destination = dest;
        _errorMessage = string.Empty;
        await RefreshExistingNames();
    }

    private async Task RefreshExistingNames()
    {
        _existingNames = [];
        _errorMessage = string.Empty;
        _isLoading = true;
        StateHasChanged(); // Show loading spinner immediately

        try
        {
            if (_destination == "local")
            {
                _existingNames = await DashboardService.ListDashboardsAsync();
            }
            else
            {
                var repo = _remoteRepos.FirstOrDefault(r => r.Name == _destination);
                if (repo != null)
                {
                    Logger.LogInformation("Loading dashboards from remote '{RepoName}'", repo.Name);
                    var remoteLogger = LoggerFactory.CreateLogger<RemoteProxyDashboardService>();
                    var service = new RemoteProxyDashboardService(Http, repo.Name, remoteLogger);
                    _existingNames = await service.ListDashboardsAsync();
                    Logger.LogInformation("Loaded {Count} dashboards from remote '{RepoName}'", _existingNames.Count, repo.Name);
                }
                else
                {
                    _errorMessage = $"Remote repository '{_destination}' not found in configuration.";
                    Logger.LogWarning("Remote repo not found: {Destination}", _destination);
                }
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dashboard list for destination {Destination}", _destination);
            _errorMessage = $"Failed to load dashboards from {_destination}: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }

        StateHasChanged();
    }

    private void Submit() => 
        MudDialog.Close(DialogResult.Ok((_destination, _name.Trim())));

    private void Cancel() => MudDialog.Cancel();
}

