@using PSTT.Dashboard.Models
@using PSTT.Dashboard.Serialization
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            <MudRadioGroup @bind-Value="_mode" T="string">
                <MudRadio Value="@("nodes")" Disabled="@(SelectedNodes.Count == 0)">
                    Selected nodes (@SelectedNodes.Count)
                </MudRadio>
                <MudRadio Value="@("page")">Current page (@(PageData?.Nodes.Count ?? 0) nodes)</MudRadio>
                <MudRadio Value="@("dashboard")" Disabled="@(DashboardData == null)">
                    Full dashboard (@(DashboardData?.Pages.Sum(p => p.Nodes.Count) ?? 0) nodes across @(DashboardData?.Pages.Count ?? 0) page(s))
                </MudRadio>
            </MudRadioGroup>

            <MudTextField Value="@Json" Label="JSON" Lines="18" ReadOnly="true"
                          Variant="Variant.Outlined"
                          Style="font-family:monospace;font-size:0.72rem;" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton StartIcon="@Icons.Material.Filled.ContentCopy"
                   Variant="Variant.Filled" Color="Color.Primary"
                   OnClick="CopyAsync">Copy to Clipboard</MudButton>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter] public List<NodeData> SelectedNodes { get; set; } = [];
    [Parameter] public DashboardPageModel? PageData { get; set; }
    [Parameter] public DashboardModel? DashboardData { get; set; }

    private string _mode = "nodes";

    private static readonly System.Text.Json.JsonSerializerOptions _jsonOpts = new()
    {
        WriteIndented = true,
        DefaultIgnoreCondition = System.Text.Json.Serialization.JsonIgnoreCondition.WhenWritingNull,
    };

    private string Json => _mode switch
    {
        "page" when PageData != null
            => DashboardSerializer.SerializePage(PageData, _jsonOpts),
        "dashboard" when DashboardData != null
            => DashboardSerializer.SerializeDashboard(DashboardData, _jsonOpts),
        _   => DashboardSerializer.SerializeNodes(SelectedNodes, _jsonOpts),
    };

    protected override void OnInitialized()
    {
        _mode = SelectedNodes.Count > 0 ? "nodes" : "page";
    }

    private async Task CopyAsync()
    {
        try
        {
            await JSRuntime.InvokeAsync<bool>("mqttClipboard.writeText", Json);
            Snackbar.Add("Copied to clipboard", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Could not write to clipboard — copy the text manually", Severity.Warning);
        }
    }

    private void Close() => MudDialog.Cancel();
}
